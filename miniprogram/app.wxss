/* ========================================
   禁毒小程序 - 守护者设计系统 (Guardian Design System)
   版本: v2.0
   核心理念: 科技蓝 + 生命绿，传递希望与守护
======================================== */

/* ---------- 1. CSS变量定义 (Design Tokens) ---------- */
page {
  /* 主题色 - 科技蓝 + 生命绿 */
  --primary: #0066FF;
  --primary-dark: #0052CC;
  --primary-light: #3385FF;
  --secondary: #00C292;
  --secondary-dark: #00A67E;
  --secondary-light: #4DD9B1;
  
  /* 强调色 - 柔和警示 */
  --accent: #FF6B6B;
  --accent-dark: #FF5252;
  --warning: #FF9800;
  --success: #10B981;
  --danger: #EF4444;
  
  /* 渐变色 */
  --gradient-primary: linear-gradient(135deg, #0066FF 0%, #00C292 100%);
  --gradient-warm: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  --gradient-card: linear-gradient(180deg, #FFFFFF 0%, #F8FAFC 100%);
  
  /* 背景色 */
  --bg-main: #F5F7FA;
  --bg-card: #FFFFFF;
  --bg-mask: rgba(0, 0, 0, 0.5);
  --bg-overlay: rgba(0, 102, 255, 0.05);
  
  /* 文字颜色 */
  --text-primary: #1A1D21;
  --text-secondary: #586376;
  --text-tertiary: #94A3B8;
  --text-inverse: #FFFFFF;
  --text-link: #0066FF;
  
  /* 边框颜色 */
  --border-light: #E2E8F0;
  --border-medium: #CBD5E1;
  --border-focus: #0066FF;
  
  /* 间距系统 (8rpx网格) */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --spacing-xxl: 64rpx;
  
  /* 圆角系统 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;
  
  /* 阴影系统 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 102, 255, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 102, 255, 0.12);
  --shadow-xl: 0 16rpx 48rpx rgba(0, 102, 255, 0.16);
  --shadow-card: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  
  /* 字体大小 */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-md: 32rpx;
  --font-lg: 36rpx;
  --font-xl: 40rpx;
  --font-xxl: 48rpx;
  
  /* 字体行高 */
  --line-height-tight: 1.2;
  --line-height-base: 1.5;
  --line-height-relaxed: 1.75;
  
  /* 过渡动画 */
  --transition-fast: 0.15s ease;
  --transition-base: 0.25s ease;
  --transition-slow: 0.4s ease;
}

/* ---------- 2. 全局重置 ---------- */
page,
view,
text,
image,
button,
input,
textarea,
scroll-view,
swiper,
swiper-item,
picker,
picker-view {
  box-sizing: border-box;
}

page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: var(--font-base);
  color: var(--text-primary);
  background-color: var(--bg-main);
  line-height: var(--line-height-base);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ---------- 3. 通用容器 ---------- */
.container {
  padding: var(--spacing-md);
  min-height: 100vh;
  box-sizing: border-box;
}

.container-fluid {
  padding-left: var(--spacing-md);
  padding-right: var(--spacing-md);
}

/* ---------- 4. 卡片样式 (Safety Card) ---------- */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-card);
  transition: all var(--transition-base);
  border: 1rpx solid var(--border-light);
}

.card-interactive {
  cursor: pointer;
}

.card-interactive:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.card-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.card-content {
  font-size: var(--font-base);
  color: var(--text-secondary);
  line-height: var(--line-height-relaxed);
}

.card-footer {
  margin-top: var(--spacing-sm);
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--border-light);
}

/* ---------- 5. 标题样式 ---------- */
.section-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--gradient-primary);
  border-radius: 4rpx;
  margin-right: var(--spacing-sm);
}

.page-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--spacing-lg);
}

/* ---------- 6. 按钮样式 ---------- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) var(--spacing-lg);
  font-size: var(--font-base);
  font-weight: 500;
  border-radius: var(--radius-full);
  border: none;
  cursor: pointer;
  transition: all var(--transition-fast);
  text-align: center;
  line-height: 1.2;
}

.btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-primary {
  background: var(--gradient-primary);
  color: var(--text-inverse);
  box-shadow: 0 8rpx 24rpx rgba(0, 102, 255, 0.3);
}

.btn-primary:active {
  box-shadow: 0 4rpx 12rpx rgba(0, 102, 255, 0.3);
}

.btn-secondary {
  background: var(--bg-card);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-danger {
  background: var(--danger);
  color: var(--text-inverse);
}

.btn-ghost {
  background: transparent;
  color: var(--primary);
}

.btn-block {
  width: 100%;
  display: flex;
}

.btn-lg {
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: var(--font-md);
}

.btn-sm {
  padding: var(--spacing-xs) var(--spacing-sm);
  font-size: var(--font-sm);
}

/* ---------- 7. 网格布局 ---------- */
.grid {
  display: grid;
  gap: var(--spacing-md);
}

.grid-2 {
  grid-template-columns: repeat(2, 1fr);
}

.grid-3 {
  grid-template-columns: repeat(3, 1fr);
}

.grid-4 {
  grid-template-columns: repeat(4, 1fr);
}

/* ---------- 8. Flex布局工具 ---------- */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-around {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

.flex-shrink-0 {
  flex-shrink: 0;
}

/* ---------- 9. 文字省略 ---------- */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.ellipsis-3 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

/* ---------- 10. 徽章样式 ---------- */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 16rpx;
  font-size: var(--font-xs);
  border-radius: var(--radius-full);
  background: var(--bg-overlay);
  color: var(--primary);
  font-weight: 500;
}

.badge-primary {
  background: var(--primary);
  color: var(--text-inverse);
}

.badge-success {
  background: rgba(16, 185, 129, 0.1);
  color: var(--success);
}

.badge-warning {
  background: rgba(255, 152, 0, 0.1);
  color: var(--warning);
}

.badge-danger {
  background: rgba(239, 68, 68, 0.1);
  color: var(--danger);
}

/* ---------- 11. 分割线 ---------- */
.divider {
  height: 1rpx;
  background: var(--border-light);
  margin: var(--spacing-md) 0;
}

.divider-dashed {
  height: 0;
  border-top: 1rpx dashed var(--border-light);
  margin: var(--spacing-md) 0;
}

/* ---------- 12. 图标容器 ---------- */
.icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
}

.icon-lg {
  width: 96rpx;
  height: 96rpx;
}

.icon-md {
  width: 64rpx;
  height: 64rpx;
}

.icon-sm {
  width: 48rpx;
  height: 48rpx;
}

.icon-xs {
  width: 32rpx;
  height: 32rpx;
}

/* ---------- 13. 表单样式 ---------- */
.input-wrapper {
  position: relative;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--spacing-md);
  font-size: var(--font-base);
  background: var(--bg-card);
  border: 2rpx solid var(--border-light);
  border-radius: var(--radius-md);
  transition: border-color var(--transition-fast);
}

.input:focus {
  border-color: var(--primary);
  outline: none;
}

.input-error {
  border-color: var(--danger);
}

.input-placeholder {
  color: var(--text-tertiary);
}

/* ---------- 14. 列表样式 ---------- */
.list-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-sm);
  transition: background var(--transition-fast);
}

.list-item:active {
  background: var(--bg-main);
}

.list-item-hover {
  cursor: pointer;
}

/* ---------- 15. 空状态 ---------- */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xxl);
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.6;
}

.empty-text {
  font-size: var(--font-base);
  color: var(--text-tertiary);
  text-align: center;
}

/* ---------- 16. 加载状态 ---------- */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* ---------- 17. 骨架屏 ---------- */
.skeleton {
  background: linear-gradient(90deg, #F0F0F0 25%, #E0E0E0 50%, #F0F0F0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: var(--radius-sm);
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* ---------- 18. 安全区域 ---------- */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

/* ---------- 19. 颜色工具类 ---------- */
.text-primary {
  color: var(--primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-tertiary {
  color: var(--text-tertiary);
}

.text-success {
  color: var(--success);
}

.text-warning {
  color: var(--warning);
}

.text-danger {
  color: var(--danger);
}

.text-center {
  text-align: center;
}

.text-left {
  text-align: left;
}

.text-right {
  text-align: right;
}

.font-bold {
  font-weight: 700;
}

.font-medium {
  font-weight: 500;
}

.font-light {
  font-weight: 300;
}

.bg-primary {
  background-color: var(--primary);
}

.bg-card {
  background-color: var(--bg-card);
}

.bg-main {
  background-color: var(--bg-main);
}

/* ---------- 20. 间距工具类 ---------- */
.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mt-xl { margin-top: var(--spacing-xl); }

.mb-xs { margin-bottom: var(--spacing-xs); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.mb-xl { margin-bottom: var(--spacing-xl); }

.ml-xs { margin-left: var(--spacing-xs); }
.ml-sm { margin-left: var(--spacing-sm); }
.ml-md { margin-left: var(--spacing-md); }
.ml-lg { margin-left: var(--spacing-lg); }

.mr-xs { margin-right: var(--spacing-xs); }
.mr-sm { margin-right: var(--spacing-sm); }
.mr-md { margin-right: var(--spacing-md); }
.mr-lg { margin-right: var(--spacing-lg); }

.p-xs { padding: var(--spacing-xs); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }
.p-xl { padding: var(--spacing-xl); }

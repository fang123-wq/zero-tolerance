/* ========================================
   个人中心样式 - 守护者设计系统 v2.0
======================================== */

/* ---------- 1. 容器 ---------- */
.container {
  padding: 0;
  background: var(--bg-main);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ---------- 2. 用户卡片 ---------- */
.user-card {
  background: var(--gradient-primary);
  border-radius: 0 0 40rpx 40rpx;
  padding: 32rpx;
  position: relative;
  overflow: hidden;
}

.card-bg-pattern {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.card-content {
  position: relative;
  z-index: 1;
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.user-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.avatar-level {
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #333;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.user-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag-item {
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.tag-text {
  font-size: 20rpx;
  color: #fff;
}

.sign-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  transition: all var(--transition-base);
}

.sign-btn:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.35);
}

.sign-btn.signed {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.2);
}

.sign-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
}

.sign-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

/* ---------- 3. 积分统计卡片 ---------- */
.user-stats-card {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx;
}

.stats-main {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 24rpx;
}

.stat-block {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.level-progress {
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.progress-value {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD700, #FFA500);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* ---------- 4. 快捷操作 ---------- */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 28rpx 32rpx;
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: var(--shadow-card);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  margin-bottom: 10rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
}

.action-name {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ---------- 5. 数据统计 ---------- */
.stats-section {
  padding: 0 32rpx;
  margin-top: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: var(--gradient-primary);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: var(--bg-main);
  border-radius: 16rpx;
}

.stat-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 12rpx;
}

.stat-icon {
  font-size: 32rpx;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.stat-name {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

/* ---------- 6. 功能菜单 ---------- */
.menu-section {
  padding: 24rpx 32rpx;
  margin-top: 24rpx;
}

.menu-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.menu-group {
  margin-bottom: 8rpx;
}

.menu-group:last-child {
  margin-bottom: 0;
}

.menu-group-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-tertiary);
  padding: 20rpx 24rpx 12rpx;
  background: #FAFAFA;
}

.menu-items {
  background: #fff;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-light);
  transition: background var(--transition-fast);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-main);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
}

.menu-icon {
  font-size: 30rpx;
}

.menu-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-extra {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* ---------- 7. 底部安全区 ---------- */
.safe-bottom {
  height: 60rpx;
}

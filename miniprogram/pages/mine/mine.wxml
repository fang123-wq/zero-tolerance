<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-header">
      <view class="user-avatar" bindtap="{{isLoggedIn ? '' : 'onLogin'}}">
        <image wx:if="{{isLoggedIn && userInfo.avatar}}" class="avatar-img" src="{{userInfo.avatar}}" mode="aspectFill"></image>
        <text wx:else class="avatar-icon">👤</text>
      </view>
      <view class="user-info">
        <text class="user-name" wx:if="{{isLoggedIn}}">{{userInfo.nickname || '禁毒志愿者'}}</text>
        <text class="user-name login-btn" wx:else bindtap="onLogin">点击登录</text>
        <text class="user-title">{{levelTitle}}</text>
      </view>
      <view class="sign-btn {{hasSignedToday ? 'signed' : ''}}" bindtap="onSign">
        <text>{{hasSignedToday ? '已签到' : '签到+10'}}</text>
      </view>
    </view>
    
    <view class="user-stats">
      <view class="stats-item-inline">
        <text class="stats-label">积分</text>
        <text class="stats-value-inline">{{points}}</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item-inline">
        <text class="stats-label">等级</text>
        <text class="stats-value-inline">Lv.{{level}}</text>
      </view>
    </view>
    
    <view class="level-progress">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{levelProgress}}%"></view>
      </view>
      <text class="progress-text">升级还需{{pointsToNext}}分</text>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-grid">
    <view class="stats-item">
      <text class="stats-value">{{completedStories}}</text>
      <text class="stats-label">故事完成</text>
    </view>
    <view class="stats-item">
      <text class="stats-value">{{correctRate}}%</text>
      <text class="stats-label">正确率</text>
    </view>
    <view class="stats-item" bindtap="showCertificates">
      <text class="stats-value">{{certificates}}</text>
      <text class="stats-label">证书</text>
    </view>
    <view class="stats-item">
      <text class="stats-value">{{heroLights}}</text>
      <text class="stats-label">点灯</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="navigateTo" data-url="/pages/learning/learning">
      <text class="menu-icon">📊</text>
      <text class="menu-name">学习记录</text>
      <text class="menu-extra">查看学习轨迹</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="navigateTo" data-url="/pages/gift/gift">
      <text class="menu-icon">🎁</text>
      <text class="menu-name">礼品兑换</text>
      <text class="menu-extra">{{points}}分可用</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="showCertificates">
      <text class="menu-icon">📜</text>
      <text class="menu-name">我的证书</text>
      <text class="menu-extra">{{certificates}}张</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="navigateTo" data-url="/pages/hero/hero">
      <text class="menu-icon">🕯️</text>
      <text class="menu-name">英雄致敬</text>
      <text class="menu-extra">{{heroLights}}次点灯</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="showPledge">
      <text class="menu-icon">✍️</text>
      <text class="menu-name">禁毒承诺</text>
      <text class="menu-extra {{pledgeSigned ? 'signed-text' : ''}}">{{pledgeSigned ? '已签署' : '未签署'}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="showHistory">
      <text class="menu-icon">📊</text>
      <text class="menu-name">兑换记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <button class="menu-item share-btn" open-type="share">
      <text class="menu-icon">🔗</text>
      <text class="menu-name">邀请好友</text>
      <text class="menu-extra highlight">+5积分</text>
      <text class="menu-arrow">›</text>
    </button>
  </view>

  <!-- 设置 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-name">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>

/* ========================================
   首页样式 - 守护者设计系统 v2.0
   核心理念: 科技蓝 + 生命绿，清新现代
======================================== */

/* ---------- 1. 容器 ---------- */
.container {
  padding: 0;
  background: var(--bg-main);
  min-height: 100vh;
}

/* ---------- 2. 顶部标题区 ---------- */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
}

.header-left {
  display: flex;
  align-items: center;
}

.logo-wrapper {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.logo-icon {
  width: 100%;
  height: 100%;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.app-title {
  font-size: 36rpx;
  font-weight: 700;
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.app-slogan {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.header-right {
  display: flex;
  align-items: center;
}

.user-avatar-mini {
  width: 64rpx;
  height: 64rpx;
  background: var(--gradient-primary);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.avatar-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* ---------- 3. Banner轮播 ---------- */
.banner {
  margin: 24rpx 32rpx;
  height: 300rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}

.banner-item {
  height: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.banner-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.banner-tag {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #fff;
  width: fit-content;
}

.banner-graphic {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.banner-icon {
  width: 120rpx;
  height: 120rpx;
}

/* ---------- 4. 区块通用 ---------- */
.section {
  margin-top: 40rpx;
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--gradient-primary);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-more {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ---------- 5. 功能网格 ---------- */
.func-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  box-shadow: var(--shadow-card);
}

.func-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: var(--bg-main);
  border-radius: 16rpx;
  transition: all var(--transition-base);
  position: relative;
  overflow: hidden;
}

.func-card:active {
  transform: scale(0.95);
  background: var(--bg-overlay);
}

.func-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--gradient-primary);
  opacity: 0;
  transition: opacity var(--transition-base);
}

.func-card:active::before {
  opacity: 1;
}

.func-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 12rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 102, 255, 0.2);
}

.func-icon {
  width: 44rpx;
  height: 44rpx;
}

.func-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.func-desc {
  font-size: 18rpx;
  color: var(--text-tertiary);
  text-align: center;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.func-arrow {
  position: absolute;
  top: 16rpx;
  right: 12rpx;
  opacity: 0;
  transform: translateX(-10rpx);
  transition: all var(--transition-base);
  color: var(--primary);
  font-size: 20rpx;
}

.func-card:active .func-arrow {
  opacity: 1;
  transform: translateX(0);
}

/* ---------- 6. 今日推荐 ---------- */
.recommend-card {
  background: var(--gradient-primary);
  border-radius: 28rpx;
  padding: 36rpx;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-xl);
}

.recommend-bg-pattern {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.recommend-content {
  position: relative;
  z-index: 1;
}

.recommend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.recommend-tag {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.tag-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.tag-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.recommend-badge {
  background: #FF6B6B;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.badge-text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 700;
}

.recommend-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.recommend-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
  margin-bottom: 20rpx;
}

.recommend-stats {
  display: flex;
  gap: 40rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  align-items: center;
}

.stat-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 4rpx;
}

.recommend-btn {
  display: inline-flex;
  align-items: center;
  background: #fff;
  color: var(--primary);
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.btn-arrow {
  margin-left: 8rpx;
  transition: transform var(--transition-base);
}

.recommend-btn:active .btn-arrow {
  transform: translateX(8rpx);
}

/* ---------- 7. 快捷工具栏 ---------- */
.quick-tools {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 32rpx;
  margin-top: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-left: 32rpx;
  margin-right: 32rpx;
  box-shadow: var(--shadow-card);
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tool-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.tool-name {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ---------- 8. 热门功能 ---------- */
.hot-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.hot-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-base);
}

.hot-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.hot-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.hot-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.hot-icon {
  font-size: 40rpx;
}

.hot-badge {
  background: var(--accent);
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-size: 18rpx;
  font-weight: 600;
}

.hot-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.hot-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 16rpx;
}

.hot-footer {
  display: flex;
  justify-content: flex-end;
}

.hot-arrow {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 500;
}

/* ---------- 9. 资讯列表 ---------- */
.news-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.news-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-base);
}

.news-card:active {
  background: var(--bg-main);
}

.news-thumb {
  width: 180rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.news-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.news-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.news-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.news-date {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.news-tag {
  font-size: 18rpx;
  color: var(--primary);
  background: var(--bg-overlay);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.news-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

/* ---------- 10. 底部安全区 ---------- */
.safe-bottom {
  height: 40rpx;
}

/* ---------- 11. 动画 ---------- */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.section {
  animation: fadeInUp 0.5s ease forwards;
}

.section:nth-child(2) { animation-delay: 0.1s; }
.section:nth-child(3) { animation-delay: 0.2s; }
.section:nth-child(4) { animation-delay: 0.3s; }
.section:nth-child(5) { animation-delay: 0.4s; }

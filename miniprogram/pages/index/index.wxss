.container {
  padding: 0 24rpx 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 顶部标题 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.header-left {
  display: flex;
  align-items: center;
}

.logo-icon {
  font-size: 56rpx;
  margin-right: 16rpx;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.app-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a237e;
}

.app-slogan {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

/* Banner */
.banner {
  height: 280rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-item {
  height: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.banner-content {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

.banner-icon {
  font-size: 80rpx;
}

/* 区块 */
.section {
  margin-top: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1a237e;
}

/* 功能网格 */
.func-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
}

.func-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.func-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.func-icon-img {
  width: 70rpx;
  height: 70rpx;
}

.func-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.func-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 推荐卡片 */
.recommend-card {
  background: linear-gradient(135deg, #1a237e, #3949ab);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recommend-left {
  flex: 1;
}

.recommend-tag {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
  margin-bottom: 16rpx;
}

.recommend-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.recommend-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.recommend-stats {
  margin-top: 16rpx;
}

.stat-item {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  margin-right: 20rpx;
}

.recommend-btn {
  background: #fff;
  color: #1a237e;
  padding: 16rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 热门功能 */
.hot-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.hot-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
}

.hot-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.hot-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.hot-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 新闻列表 */
.news-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.news-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.news-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.news-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.news-date {
  font-size: 22rpx;
  color: #999;
}

.news-tag {
  font-size: 20rpx;
  color: #1a237e;
  background: #e8eaf6;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.news-arrow {
  font-size: 28rpx;
  color: #ccc;
  flex-shrink: 0;
}

.news-item:active {
  background: #f8f9fa;
}

/* 底部安全区 */
.safe-bottom {
  height: 20rpx;
}

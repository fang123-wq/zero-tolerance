  <!-- 趣味小游戏 -->
  <view class="section">
    <view class="section-title">趣味小游戏</view>
    <view class="game-grid">
      <view class="game-item" wx:for="{{games}}" wx:key="id" bindtap="startGame" data-game="{{item}}">
        <image wx:if="{{item.id === 'claw'}}" class="game-icon-img" src="/assets/images/racing-car.png" mode="aspectFit"></image>
        <text wx:else class="game-icon">{{item.icon}}</text>
        <text class="game-name">{{item.name}}</text>
        <text class="game-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 沉浸式故事 -->
  <view class="section">
    <view class="section-title">沉浸式故事</view>
    <view class="story-list">
      <view class="story-card" wx:for="{{stories}}" wx:key="id" bindtap="startStory" data-story="{{item}}">
        <view class="story-icon">{{item.icon}}</view>
        <view class="story-content">
          <view class="story-header">
            <text class="story-title">{{item.title}}</text>
            <view class="story-badge new" wx:if="{{item.isNew}}">NEW</view>
            <view class="story-badge" wx:elif="{{completedStories.includes(item.id)}}">已完成</view>
          </view>
          <text class="story-subtitle">{{item.subtitle}}</text>
          <view class="story-meta">
            <text class="meta-item">⭐ {{item.rating}}</text>
            <text class="meta-item">⏱️ {{item.duration}}</text>
            <text class="meta-item">👥 {{item.playCount}}人体验</text>
          </view>
        </view>
        <view class="story-arrow">→</view>
      </view>
    </view>
  </view>

  <!-- 学习进度 -->
  <view class="section">
    <view class="section-title">我的进度</view>
    <view class="progress-card">
      <view class="progress-item">
        <text class="progress-value">{{completedStories.length}}/{{stories.length}}</text>
        <text class="progress-label">故事完成</text>
      </view>
      <view class="progress-divider"></view>
      <view class="progress-item">
        <text class="progress-value">{{totalPoints}}</text>
        <text class="progress-label">当前积分</text>
      </view>
    </view>
  </view>
</view>

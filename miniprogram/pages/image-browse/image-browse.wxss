.container {
  min-height: 100vh;
  background-color: #ffffff;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.image-swiper {
  width: 100%;
  height: 70vh;
}

.browse-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.page-indicator {
  text-align: center;
  padding: 20rpx 0;
  color: #333;
  font-size: 28rpx;
}

.thumbnail-list {
  padding: 20rpx;
  background-color: #ffffff;
}

.thumbnail-scroll {
  white-space: nowrap;
}

.thumbnail-item {
  display: inline-block;
  width: 120rpx;
  height: 120rpx;
  margin-right: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  box-sizing: border-box;
}

.thumbnail-item.active {
  border-color: #1a237e;
}

.thumbnail-item image {
  width: 100%;
  height: 100%;
}

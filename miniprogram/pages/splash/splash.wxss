.splash-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.bg-gradient {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #0d1b4c 0%, #1a237e 50%, #283593 100%);
  z-index: -1;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 8rpx;
}

.impact-section {
  margin: 40rpx 0;
  animation: fadeIn 1s ease-in;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.impact-box {
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 30rpx 40rpx;
  text-align: center;
}

.impact-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
}

.impact-number {
  font-size: 30rpx;
  color: #fff;
  margin: 16rpx 0;
}

.impact-number .highlight {
  font-size: 56rpx;
  font-weight: bold;
  color: #ff5252;
  margin: 0 8rpx;
  animation: countUp 0.5s ease-out;
}

@keyframes countUp {
  from { opacity: 0; transform: scale(0.5); }
  to { opacity: 1; transform: scale(1); }
}

.loading-section {
  width: 60%;
  margin-top: 60rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #64b5f6, #42a5f5);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.loading-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
  margin-top: 16rpx;
}

.visit-count {
  margin-top: 40rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.visit-count .count {
  color: #64b5f6;
  font-weight: bold;
}

.footer {
  position: absolute;
  bottom: 80rpx;
  text-align: center;
}

.org-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

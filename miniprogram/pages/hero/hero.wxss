.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.video-panel {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-video {
  width: 100%;
  height: 56.25vw;
}

/* 选择面板 */
.choice-panel {
  width: 100%;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.choice-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  margin-bottom: 60rpx;
  line-height: 1.6;
}

.choice-options {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 0 20rpx;
}

.choice-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(255,255,255,0.2);
  transition: all 0.3s;
}

.choice-btn:active {
  transform: scale(0.97);
}

.choice-btn-1 {
  background: linear-gradient(135deg, rgba(220,53,69,0.3) 0%, rgba(176,42,55,0.2) 100%);
  border-color: rgba(220,53,69,0.5);
}

.choice-btn-2 {
  background: linear-gradient(135deg, rgba(40,167,69,0.3) 0%, rgba(32,134,55,0.2) 100%);
  border-color: rgba(40,167,69,0.5);
}

.choice-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.choice-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.choice-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

/* 结束面板 */
.end-panel {
  width: 100%;
  padding: 80rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.end-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffc107;
  margin-bottom: 32rpx;
}

.end-desc {
  font-size: 30rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.8;
  text-align: center;
  margin-bottom: 60rpx;
}

.end-actions {
  display: flex;
  gap: 30rpx;
}

.restart-btn {
  padding: 20rpx 50rpx;
  background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
  color: #1a1a2e;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
}

.restart-btn:active {
  opacity: 0.85;
}

.back-btn {
  padding: 20rpx 50rpx;
  background: rgba(255,255,255,0.15);
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
}

.back-btn:active {
  opacity: 0.85;
}

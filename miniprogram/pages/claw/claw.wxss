/* pages/claw/claw.wxss - 禁毒飞车冲刺 */
page {
  background: #0a0a2e;
  height: 100%;
  overflow: hidden;
}

.container {
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* ========== 游戏Canvas ========== */
.game-canvas {
  width: 100%;
  height: 100vh;
}

/* ========== 血量条覆盖层（独立显示） ========== */
.hp-overlay {
  position: fixed;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10000;
  pointer-events: none;
}

.hp-container {
  background: rgba(0, 0, 0, 0.9);
  padding: 20rpx 40rpx;
  border-radius: 30rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 300rpx;
}

.hp-label {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.hp-bar-simple {
  width: 100%;
  height: 40rpx;
  background: #333;
  border-radius: 20rpx;
  overflow: hidden;
  border: 3rpx solid #fff;
  margin-bottom: 8rpx;
}

.hp-fill-simple {
  height: 100%;
  background: #f44336;
  box-shadow: 0 0 20rpx rgba(244, 67, 54, 1);
  transition: width 0.3s ease;
}

.hp-value {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 1);
}

/* ========== HUD ========== */
.hud {
  position: fixed;
  top: 120rpx;
  left: 0;
  right: 0;
  width: 100%;
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 9999;
  pointer-events: none;
}

.hud-left, .hud-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(0,0,0,0.85);
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.6);
}

.hud-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  font-weight: bold;
}

.hud-val {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5);
}

.hud-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  margin: 0 20rpx;
  min-width: 200rpx;
}

.hp-bar-container {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(0,0,0,0.95);
  padding: 20rpx 30rpx;
  border-radius: 24rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.9);
}

.hp-bar {
  width: 100%;
  height: 36rpx;
  background: #333;
  border-radius: 18rpx;
  overflow: hidden;
  border: 3rpx solid #fff;
  box-shadow: inset 0 2rpx 8rpx rgba(0,0,0,0.9);
}

.hp-fill {
  height: 100%;
  background: #f44336;
  border-radius: 15rpx;
  transition: width 0.3s ease;
  box-shadow: 0 0 20rpx rgba(244, 67, 54, 1);
  position: relative;
}

.hp-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.5) 0%, transparent 100%);
  border-radius: 15rpx 15rpx 0 0;
}

.hp-text {
  font-size: 28rpx;
  color: #fff;
  margin-top: 12rpx;
  font-weight: bold;
  text-shadow: 0 3rpx 10rpx rgba(0,0,0,1);
  letter-spacing: 2rpx;
}

.score-val {
  color: #ffd700;
}

/* ========== 设置按钮和面板 ========== */
.settings-btn {
  position: fixed;
  top: 180rpx;
  right: 16rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  z-index: 20;
}

.settings-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.settings-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
}

.settings-card {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 500rpx;
  background: #1a1a4e;
  border-radius: 24rpx;
  padding: 40rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
}

.settings-title {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 30rpx;
}

.settings-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.settings-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
}

.settings-close {
  text-align: center;
  margin-top: 30rpx;
  padding: 16rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 30rpx;
  color: rgba(255,255,255,0.7);
  font-size: 26rpx;
}

/* ========== 积分高亮 ========== */
.highlight-row {
  background: rgba(255,215,0,0.1);
  border-radius: 8rpx;
  margin-top: 8rpx;
}

.score-highlight {
  color: #ffd700 !important;
  font-size: 34rpx !important;
}

/* ========== 开始界面 ========== */
.start-screen {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #0a0a2e 0%, #1a1a4e 50%, #0d2137 100%);
  overflow-y: auto;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.settings-btn-bottom {
  margin: 30rpx auto;
  padding: 20rpx 60rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 40rpx;
  text-align: center;
  border: 2rpx solid rgba(255,255,255,0.2);
}

.settings-icon-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
}

/* 旅程排行榜 */
.ranking-section {
  background: rgba(255,255,255,0.08);
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 24rpx 0;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.my-journey-tag {
  font-size: 22rpx;
  color: #00bcd4;
  font-weight: bold;
}

.ranking-list {
  margin-top: 16rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.rank-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  font-weight: bold;
  margin-right: 16rpx;
}

.rank-top {
  background: linear-gradient(135deg, #ffd700, #ff9800);
  color: #fff;
}

.rank-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: rgba(255,255,255,0.1);
}

.rank-name {
  flex: 1;
  font-size: 26rpx;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-journey {
  font-size: 24rpx;
  color: #00bcd4;
  font-weight: bold;
}

.btn-share {
  margin-top: 20rpx;
  padding: 16rpx;
  background: rgba(0,188,212,0.2);
  border: 2rpx solid rgba(0,188,212,0.4);
  border-radius: 40rpx;
  color: #00bcd4;
  font-size: 26rpx;
  text-align: center;
}

.btn-share::after {
  border: none;
}

.points-box, .plays-box {
  background: rgba(255,255,255,0.1);
  padding: 16rpx 28rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pts-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

.pts-val {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffd700;
}

.free-tag {
  font-size: 20rpx;
  color: #4caf50;
  margin-top: 4rpx;
}

/* 赛车主视觉 */
.hero-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 30rpx;
}

.car-display {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0,188,212,0.3) 0%, transparent 70%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  animation: carFloat 2s ease-in-out infinite;
}

@keyframes carFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.car-image {
  width: 160rpx;
  height: 160rpx;
}

.game-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 0 20rpx rgba(0,188,212,0.5);
}

.game-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  line-height: 1.6;
}

/* 血量条预览 */
.hp-preview {
  margin-top: 40rpx;
  width: 100%;
  max-width: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hp-preview-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 12rpx;
  font-weight: bold;
}

.hp-preview-bar {
  width: 100%;
  height: 32rpx;
  background: rgba(50,50,50,0.8);
  border-radius: 16rpx;
  overflow: hidden;
  border: 3rpx solid rgba(255,255,255,0.4);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.5);
  position: relative;
}

.hp-preview-fill {
  height: 100%;
  width: 100%;
  background: linear-gradient(90deg, #f44336 0%, #ff9800 50%, #4caf50 100%);
  border-radius: 14rpx;
  box-shadow: 0 0 16rpx rgba(76, 175, 80, 0.8);
  animation: hpPulse 2s ease-in-out infinite;
}

@keyframes hpPulse {
  0%, 100% { 
    box-shadow: 0 0 16rpx rgba(76, 175, 80, 0.8);
  }
  50% { 
    box-shadow: 0 0 24rpx rgba(76, 175, 80, 1);
  }
}

.hp-preview-text {
  font-size: 22rpx;
  color: rgba(255,100,100,0.9);
  margin-top: 12rpx;
}

/* 玩法说明 */
.rules-card {
  background: rgba(255,255,255,0.08);
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 24rpx 0;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.rule-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.rule-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  width: 48rpx;
  text-align: center;
}

.rule-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 开始按钮 */
.start-btn {
  width: 80%;
  margin: 30rpx auto 16rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #00bcd4, #0097a7);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(0,188,212,0.4);
}

.start-btn.disabled {
  background: #555;
  box-shadow: none;
}

.start-btn::after {
  border: none;
}

.start-text {
  font-size: 34rpx;
  font-weight: bold;
}

.start-cost {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

.tip-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #ff9800;
  margin-top: 12rpx;
}

.guarantee-bar {
  text-align: center;
  margin: 16rpx 0;
  padding: 12rpx 24rpx;
  background: rgba(255,152,0,0.15);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ffd700;
}

/* 奖品展示 */
.prize-section {
  background: rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.sec-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
}

.prize-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.prize-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.08);
}

.prize-card.epic {
  background: rgba(255,215,0,0.15);
  border: 1rpx solid rgba(255,215,0,0.3);
}

.prize-card.rare {
  background: rgba(76,175,80,0.15);
  border: 1rpx solid rgba(76,175,80,0.3);
}

.prize-image {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 8rpx;
}

.prize-name {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

/* 中奖记录 */
.record-section {
  background: rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.sec-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.stat-tag {
  font-size: 22rpx;
  color: #ff6b6b;
  background: rgba(255,107,107,0.15);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.record-list {
  max-height: 360rpx;
  overflow-y: auto;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  flex-direction: column;
}

.record-name {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

.record-time {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
  margin-top: 4rpx;
}

.record-points {
  font-size: 30rpx;
  color: #ffd700;
  font-weight: bold;
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: rgba(255,255,255,0.4);
  font-size: 24rpx;
}

.btn-gift {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #00bcd4, #0097a7);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.btn-gift::after {
  border: none;
}

/* ========== 结果界面 ========== */
.result-screen {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: linear-gradient(180deg, #0a0a2e, #1a1a4e);
}

.result-card {
  width: 100%;
  background: rgba(255,255,255,0.08);
  border-radius: 28rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.result-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 30rpx;
}

.result-stats {
  width: 100%;
  background: rgba(0,0,0,0.2);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 16rpx;
}

.stat-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
}

.stat-value {
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
}

/* 抽奖中 */
.lottery-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255,255,255,0.2);
  border-top-color: #00bcd4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.drawing-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

/* 中奖 */
.win-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  animation: fadeInUp 0.5s ease;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.win-label {
  font-size: 30rpx;
  color: #ffd700;
  margin-bottom: 16rpx;
}

.win-prize {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.win-img {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 12rpx;
}

.win-points {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffd700;
  text-shadow: 0 0 20rpx rgba(255,215,0,0.5);
}

.win-name {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

/* 未中奖 */
.lose-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  animation: fadeInUp 0.5s ease;
}

.lose-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 16rpx;
}

/* 结果按钮 */
.result-btns {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-top: 30rpx;
}

.btn-back, .btn-retry {
  flex: 1;
  padding: 24rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.btn-back {
  background: rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.8);
}

.btn-retry {
  background: linear-gradient(135deg, #00bcd4, #0097a7);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(0,188,212,0.3);
}

.btn-back::after, .btn-retry::after {
  border: none;
}

.btn-retry[disabled] {
  background: #555;
  box-shadow: none;
  color: #999;
}

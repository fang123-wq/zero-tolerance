/* pages/learning/learning.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
}

.back-btn {
  font-size: 48rpx;
  color: #fff;
  margin-right: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  padding: 10rpx 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  border-radius: 10rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-weight: bold;
}

.content {
  flex: 1;
  padding: 20rpx;
}

/* 统计面板 */
.stats-panel {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin: 30rpx 0 20rpx;
}

.stats-title:first-child {
  margin-top: 0;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.stats-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 15rpx;
  padding: 30rpx;
  text-align: center;
  color: #fff;
}

.stats-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.stats-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
}

.stats-detail {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #e9ecef;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.detail-value.highlight {
  color: #667eea;
  font-size: 32rpx;
}

/* 记录列表 */
.record-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.record-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-extra {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.duration-text {
  font-size: 24rpx;
  color: #667eea;
  margin-bottom: 5rpx;
}

.score-text {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.rate-text {
  font-size: 24rpx;
  color: #667eea;
}

.ending-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

.ending-badge.good {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.ending-badge.bad {
  background: #95a5a6;
}

.complete-badge {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #52c41a;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  margin-top: 5rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-tip {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 24rpx;
}

.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 成绩卡片 */
.score-card {
  background: linear-gradient(135deg, #1a237e, #3949ab);
  border-radius: 20rpx;
  padding: 36rpx;
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.score-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.score-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.score-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
}

/* 区块 */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1a237e;
}

/* 模式网格 */
.mode-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.mode-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mode-card.disabled {
  opacity: 0.5;
}

.mode-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.mode-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.mode-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}

.mode-points {
  font-size: 22rpx;
  color: #1a237e;
  margin-top: 8rpx;
  background: #e8eaf6;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* 答题面板 */
.quiz-panel {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.quiz-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.quiz-progress {
  font-size: 28rpx;
  color: #666;
}

.quiz-timer {
  font-size: 28rpx;
  color: #f44336;
  font-weight: bold;
}

.question-card {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.question-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

/* 选项 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  background: #f9f9f9;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 24rpx;
}

.option-item.selected {
  border-color: #1a237e;
  background: #e8eaf6;
}

.option-item.correct {
  border-color: #4caf50;
  background: #e8f5e9;
}

.option-item.wrong {
  border-color: #f44336;
  background: #ffebee;
}

.option-text {
  font-size: 28rpx;
  color: #333;
}

/* 答案解释 */
.answer-explanation {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #fff8e1;
  border-radius: 12rpx;
}

.explanation-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.explanation-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.btn-next {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #1a237e, #3949ab);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
}

/* 排行榜 */
.rank-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-medal {
  font-size: 32rpx;
  width: 60rpx;
}

.rank-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.rank-score {
  font-size: 28rpx;
  color: #1a237e;
  font-weight: bold;
}

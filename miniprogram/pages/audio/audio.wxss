/* pages/audio/audio.wxss */
.audio-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  padding-top: env(safe-area-inset-top);
  background: rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 20rpx;
  padding-right: 20rpx;
  z-index: 100;
}

.back-btn {
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 28rpx;
  padding: 10rpx 20rpx;
}

.back-icon {
  margin-right: 8rpx;
}

.title {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.list-btn {
  padding: 10rpx 20rpx;
  font-size: 36rpx;
}

/* 封面轮播 */
.cover-area {
  width: 100%;
  height: 400rpx;
  margin-top: calc(88rpx + env(safe-area-inset-top));
  position: relative;
  overflow: hidden;
}

.cover-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #1890ff 0%, #722ed1 50%, #eb2f96 100%);
}

.cover-content {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.cover-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.cover-zone {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.cover-image {
  width: 100%;
  height: 100%;
}

/* 内容展示区 */
.content-area {
  flex: 1;
  padding: 30rpx;
  padding-bottom: 280rpx;
}

.audio-title {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.title-number {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.title-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

/* 讲解文字滚动区 */
.transcript-scroll {
  height: calc(100vh - 750rpx - env(safe-area-inset-top));
}

.transcript-section {
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-label {
  color: #1890ff;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.transcript-text {
  color: rgba(255,255,255,0.9);
  font-size: 28rpx;
  line-height: 1.8;
}

/* 知识要点 */
.keypoints-section {
  background: rgba(24,144,255,0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(24,144,255,0.3);
}

.keypoints-list {
  margin-top: 16rpx;
}

.keypoint-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.keypoint-dot {
  color: #52c41a;
  font-size: 32rpx;
  margin-right: 12rpx;
  line-height: 1.5;
}

.keypoint-text {
  color: #fff;
  font-size: 26rpx;
  line-height: 1.5;
  flex: 1;
}

/* 播放控制区 */
.player-control {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.9);
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.progress-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.time-text {
  color: rgba(255,255,255,0.7);
  font-size: 24rpx;
  width: 80rpx;
  text-align: center;
}

.progress-slider {
  flex: 1;
  margin: 0 10rpx;
}

/* 控制按钮 */
.control-buttons {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 20rpx;
}

.control-btn.active {
  background: rgba(24,144,255,0.3);
  border-radius: 12rpx;
}

.btn-icon {
  font-size: 40rpx;
}

.btn-icon.large {
  font-size: 72rpx;
}

.btn-label {
  color: rgba(255,255,255,0.7);
  font-size: 22rpx;
  margin-top: 4rpx;
}

.play-btn {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-btn .btn-icon {
  font-size: 56rpx;
}

/* 播放列表弹窗 */
.playlist-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  z-index: 200;
  display: none;
}

.playlist-modal.show {
  display: flex;
  align-items: flex-end;
}

.playlist-content {
  width: 100%;
  max-height: 70vh;
  background: #1a1a2e;
  border-radius: 30rpx 30rpx 0 0;
  display: flex;
  flex-direction: column;
}

.playlist-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
}

.playlist-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.playlist-close {
  color: rgba(255,255,255,0.7);
  font-size: 36rpx;
  padding: 10rpx;
}

.playlist-scroll {
  flex: 1;
  max-height: 50vh;
}

.playlist-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}

.playlist-item.active {
  background: rgba(24,144,255,0.2);
}

.playlist-item.listened .item-status {
  color: #52c41a;
}

.item-status {
  width: 50rpx;
  font-size: 28rpx;
}

.item-number {
  color: rgba(255,255,255,0.5);
  font-size: 24rpx;
  width: 50rpx;
}

.item-title {
  flex: 1;
  color: #fff;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-duration {
  color: rgba(255,255,255,0.5);
  font-size: 24rpx;
  margin-left: 20rpx;
}

.playlist-footer {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.6);
  font-size: 24rpx;
}

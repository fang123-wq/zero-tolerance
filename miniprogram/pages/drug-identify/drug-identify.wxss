/* pages/drug-identify/drug-identify.wxss */

.page {
  min-height: 100vh;
  background: #f5f6fa;
}

/* 顶部背景 */
.header-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(135deg, #1e3c72 0%, #2a5298 50%, #1e3c72 100%);
  z-index: 0;
}

.header-bg::before {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  height: 80rpx;
  background: #f5f6fa;
  border-radius: 40rpx 40rpx 0 0;
}

/* 主内容 */
.main-content {
  position: relative;
  z-index: 1;
  padding: 0 28rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 页面标题 */
.page-header {
  padding: 48rpx 0 40rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 2rpx;
}

/* 卡片通用样式 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.card-count {
  font-size: 24rpx;
  color: #9ca3af;
  background: #f3f4f6;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 标签样式 */
.danger-tag {
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #ef4444, #dc2626);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.warning-tag {
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

/* 图片网格 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-grid.two-col .image-card {
  width: calc(50% - 8rpx);
}

.image-grid.three-col .image-card {
  width: calc(33.33% - 11rpx);
}

/* 图片卡片 */
.image-card {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background: #e5e7eb;
}

.image-card:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.card-image {
  width: 100%;
  height: 200rpx;
  display: block;
}

.image-grid.three-col .card-image {
  height: 160rpx;
}

.image-card.large .card-image {
  height: 240rpx;
}

/* 图片遮罩 */
.image-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, transparent 50%, rgba(0, 0, 0, 0.4) 100%);
  pointer-events: none;
}

/* 图片标题 */
.image-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12rpx;
  font-size: 22rpx;
  color: #fff;
  text-align: center;
  font-weight: 500;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.image-grid.three-col .image-title {
  font-size: 20rpx;
  padding: 8rpx;
}

/* 危害卡片 */
.danger-card {
  border-top: 4rpx solid #ef4444;
}

/* 警告卡片 */
.warning-card {
  border-top: 4rpx solid #f59e0b;
}

/* 提示卡片 */
.tips-card {
  border-top: 4rpx solid #10b981;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(16, 185, 129, 0.15);
}

.tip-num {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #10b981, #059669);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.5;
}

/* 底部留白 */
.footer-space {
  height: 40rpx;
}

/* PDF卡片 */
.pdf-card {
  border-top: 4rpx solid #3b82f6;
  padding: 24rpx 28rpx;
}

.pdf-card:active {
  background: #f8fafc;
}

.pdf-content {
  display: flex;
  align-items: center;
}

.pdf-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.pdf-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.pdf-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.pdf-desc {
  font-size: 24rpx;
  color: #9ca3af;
}

.pdf-arrow {
  font-size: 48rpx;
  color: #d1d5db;
  font-weight: 300;
}
